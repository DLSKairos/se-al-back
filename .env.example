# ─── Base de datos ────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/senal_db

# ─── App ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://tu-frontend.com

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=8h

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── WebAuthn ─────────────────────────────────────────────
WEBAUTHN_RP_ID=tu-dominio.com
WEBAUTHN_RP_NAME=SEÑAL
WEBAUTHN_ORIGIN=https://tu-frontend.com

# ─── Push Notifications (VAPID) ───────────────────────────
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@tu-dominio.com

# ─── Email (Resend) ───────────────────────────────────────
# Crear API key en: https://resend.com/api-keys
# Verificar dominio en: https://resend.com/domains
RESEND_API_KEY=re_...
RESEND_FROM=SEÑAL <no-reply@señal.kairosdls.com>

# ─── Anthropic ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Cloudinary ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── OAuth Google (requiere feature flag: feature:oauth_google) ───────────
# Guía de configuración: docs/setup/oauth-google.md
# Crear credenciales en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Desarrollo:    https://localhost:3000/api/auth/google/callback
# Producción:    https://api.tu-dominio.com/api/auth/google/callback
GOOGLE_CALLBACK_URL=https://localhost:3000/api/auth/google/callback

# ─── OAuth Microsoft (requiere feature flag: feature:oauth_microsoft) ─────
# Guía de configuración: docs/setup/oauth-microsoft.md
# Crear app en: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# 'common' permite cuentas de cualquier tenant + cuentas personales Microsoft
MICROSOFT_TENANT_ID=common
# Desarrollo:    https://localhost:3000/api/auth/microsoft/callback
# Producción:    https://api.tu-dominio.com/api/auth/microsoft/callback
MICROSOFT_CALLBACK_URL=https://localhost:3000/api/auth/microsoft/callback

# ─── Cifrado ──────────────────────────────────────────────────────────────
# Usado para cifrar tokens OAuth y datos sensibles con AES-256
# Generar con: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── Magic Link ───────────────────────────────────────────────────────────
# Requiere feature flag: feature:magic_link
# Clave HMAC para firmar los tokens de magic link
MAGIC_LINK_SECRET=
# URL base del frontend donde el admin completa el flujo de activación
# Ejemplo desarrollo: https://localhost:4000
# Ejemplo producción: https://app.tu-dominio.com
MAGIC_LINK_BASE_URL=https://localhost:4000

# ─── Firma electrónica ────────────────────────────────────────────────────
# Requiere feature flag: feature:electronic_signature
# TTL del token de firma en horas (default 2 — un solo uso)
SIGNATURE_TOKEN_TTL_HOURS=2
