# ─── Base de datos ────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/senal_db

# ─── App ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://tu-frontend.com

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=8h

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── WebAuthn ─────────────────────────────────────────────
WEBAUTHN_RP_ID=tu-dominio.com
WEBAUTHN_RP_NAME=SEÑAL
WEBAUTHN_ORIGIN=https://tu-frontend.com

# ─── Push Notifications (VAPID) ───────────────────────────
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@tu-dominio.com

# ─── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tu-dominio.com

# ─── Anthropic ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Cloudinary ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
