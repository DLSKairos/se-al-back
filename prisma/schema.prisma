// Prisma schema — SEÑAL
// SaaS B2B de automatización de formularios operacionales SST (Colombia)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ORGANIZACIÓN ─────────────────────────────────────────

model Organization {
  id         String   @id @default(cuid())
  name       String   @unique
  created_at DateTime @default(now())

  users               User[]
  departments         Department[]
  work_locations      WorkLocation[]
  form_categories     FormCategory[]
  form_templates      FormTemplate[]
  form_blueprints     FormBlueprint[]
  submissions         FormSubmission[]
  attendance_config   AttendanceConfig?
  webhook_endpoints   WebhookEndpoint[]
  attendance_records  AttendanceRecord[]
  inventario_sessions InventarioSession[]
  external_signers         ExternalSigner[]
  config                   OrgConfig?
  master_positions         MasterPosition[]
  master_roles             MasterRole[]
  master_list_suggestions  MasterListSuggestion[]

  @@map("organizations")
}

model Department {
  id     String  @id @default(cuid())
  org_id String?          // null = global (seed de Kairos)
  name   String
  email  String?          // no aplica para globales
  active Boolean @default(true)

  org            Organization?  @relation(fields: [org_id], references: [id])
  work_locations WorkLocation[]

  @@unique([org_id, name])
  @@index([org_id, active])
  @@map("departments")
}

model WorkLocation {
  id            String   @id @default(cuid())
  org_id        String
  department_id String?
  name          String
  contractor    String
  lat           Decimal  @db.Decimal(10, 6)
  lng           Decimal  @db.Decimal(10, 6)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  org              Organization       @relation(fields: [org_id], references: [id])
  department       Department?        @relation(fields: [department_id], references: [id])
  users            User[]
  attendances      AttendanceRecord[]
  form_submissions FormSubmission[]
  external_signers ExternalSigner[]

  @@unique([org_id, name])
  @@index([org_id, is_active])
  @@map("work_locations")
}

// ─── USUARIOS Y AUTENTICACIÓN ─────────────────────────────

model User {
  id                    String         @id @default(cuid())
  org_id                String
  work_location_id      String?
  name                  String
  identification_number String         @unique
  email                 String?        @unique
  job_title             String         @default("Sin cargo")
  role                  UserRole       @default(OPERATOR)
  is_active             Boolean        @default(true)
  pin_enabled           Boolean        @default(false)
  pin_hash              String?
  oauth_provider        OAuthProvider?
  oauth_provider_id     String?
  oauth_access_token    String?        @db.Text
  oauth_refresh_token   String?        @db.Text
  last_oauth_sync       DateTime?
  position_id           String?
  created_at            DateTime       @default(now())

  org                  Organization         @relation(fields: [org_id], references: [id])
  work_location        WorkLocation?        @relation(fields: [work_location_id], references: [id])
  webauthn_credentials WebAuthnCredential[]
  push_subscription    PushSubscription?
  attendances          AttendanceRecord[]
  submissions          FormSubmission[]
  templates_created    FormTemplate[]
  notifications                Notification[]       @relation("UserNotifications")
  sent_notifications           Notification[]       @relation("AdminCreatedNotifications")
  internal_signature_records   SignatureRecord[]    @relation("InternalSignerRecords")
  magic_link_tokens            MagicLinkToken[]     @relation("UserMagicLinks")
  org_config_updates           OrgConfig[]          @relation("SuperAdminOrgConfigUpdates")
  position                     MasterPosition?      @relation("UserPosition", fields: [position_id], references: [id], onDelete: SetNull)
  suggestions_made             MasterListSuggestion[] @relation("SuggestedByUser")
  suggestions_reviewed         MasterListSuggestion[] @relation("ReviewedByUser")
  rejected_submissions         FormSubmission[]     @relation("RejectedByAdmin")

  @@index([org_id, is_active])
  @@index([oauth_provider, oauth_provider_id])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
}

model WebAuthnCredential {
  id                 String   @id @default(cuid())
  user_id            String
  credential_id      String   @unique
  public_key         String   @db.Text
  sign_count         Int      @default(0)
  authenticator_type String?
  registered_at      DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, credential_id])
  @@map("webauthn_credentials")
}

model PushSubscription {
  user_id      String   @id
  subscription Json
  created_at   DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// ─── ASISTENCIA ───────────────────────────────────────────

model AttendanceConfig {
  id                   String  @id @default(cuid())
  org_id               String  @unique
  is_enabled           Boolean @default(false)
  standard_daily_hours Float   @default(8.0)
  night_shift_start    String  @default("21:00")
  night_shift_end      String  @default("06:00")
  sunday_surcharge     Boolean @default(true)
  holiday_surcharge    Boolean @default(true)
  custom_holidays      Json    @default("[]")

  org Organization @relation(fields: [org_id], references: [id])

  @@map("attendance_config")
}

model AttendanceRecord {
  id               String    @id @default(cuid())
  org_id           String
  user_id          String
  work_location_id String?
  service_date     DateTime  @db.Date
  entry_time       DateTime  @db.Time(6)
  exit_time        DateTime? @db.Time(6)
  lunch_minutes    Int?

  total_minutes         Int?
  regular_minutes       Int?
  extra_day_minutes     Int?
  extra_night_minutes   Int?
  extra_sunday_minutes  Int?
  extra_holiday_minutes Int?

  org           Organization  @relation(fields: [org_id], references: [id])
  user          User          @relation(fields: [user_id], references: [id])
  work_location WorkLocation? @relation(fields: [work_location_id], references: [id])

  @@index([org_id, service_date])
  @@index([user_id, service_date])
  @@index([user_id, org_id, service_date])
  @@map("attendance_records")
}

// ─── FORM BUILDER ─────────────────────────────────────────

model FormCategory {
  id         String   @id @default(cuid())
  org_id     String
  name       String
  is_sst     Boolean  @default(false)
  created_at DateTime @default(now())

  org       Organization   @relation(fields: [org_id], references: [id])
  templates FormTemplate[]

  @@unique([org_id, name])
  @@map("form_categories")
}

model FormTemplate {
  id                  String             @id @default(cuid())
  org_id              String
  category_id         String
  name                String
  description         String?
  icon                String?
  status              FormTemplateStatus @default(DRAFT)
  data_frequency      Frequency          @default(ONCE)
  signature_frequency Frequency          @default(NONE)
  export_pdf          Boolean            @default(true)
  export_excel        Boolean            @default(false)
  target_job_titles   String[]           @default([])
  columns             Int                @default(1)
  source_file_url     String?
  sections            Json?
  created_by          String
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt

  org              Organization       @relation(fields: [org_id], references: [id])
  category         FormCategory       @relation(fields: [category_id], references: [id])
  creator          User               @relation(fields: [created_by], references: [id])
  fields           FormField[]
  notifications    FormNotification[]
  submissions      FormSubmission[]
  signature_config SignatureConfig?

  @@index([org_id, status])
  @@map("form_templates")
}

model FormField {
  id                     String    @id @default(cuid())
  template_id            String
  order                  Int
  label                  String
  key                    String
  type                   FieldType
  required               Boolean   @default(true)
  default_value          String?
  options                Json?
  validations            Json?
  revalidation_frequency Frequency @default(INHERIT)
  section                String?
  placeholder            String?
  help_text              String?

  template FormTemplate          @relation(fields: [template_id], references: [id], onDelete: Cascade)
  values   FormSubmissionValue[]

  @@unique([template_id, key])
  @@map("form_fields")
}

model FormNotification {
  id          String              @id @default(cuid())
  template_id String
  trigger     NotificationTrigger
  recipients  Json
  channels    Json
  subject     String?
  body        String?
  enabled     Boolean             @default(true)

  template FormTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@map("form_notifications")
}

model FormSubmission {
  id               String           @id @default(cuid())
  template_id      String
  org_id           String
  submitted_by     String
  work_location_id String?
  submitted_at     DateTime         @default(now())
  status           SubmissionStatus @default(SUBMITTED)
  period_key       String?
  data             Json
  geo_lat          Float?
  geo_lng          Float?
  review_notes     String?

  auto_approved_at     DateTime?
  rejected_at          DateTime?
  rejected_by_admin_id String?
  rejection_reason     String?   @db.Text

  template          FormTemplate          @relation(fields: [template_id], references: [id])
  org               Organization          @relation(fields: [org_id], references: [id])
  submitter         User                  @relation(fields: [submitted_by], references: [id])
  work_location     WorkLocation?         @relation(fields: [work_location_id], references: [id])
  rejected_by_admin User?                 @relation("RejectedByAdmin", fields: [rejected_by_admin_id], references: [id], onDelete: SetNull)
  values            FormSubmissionValue[]
  signatures        FormSignature[]
  signature_tokens  SignatureToken[]
  signature_records SignatureRecord[]

  @@index([template_id, org_id, period_key])
  @@index([org_id, submitted_at(sort: Desc)])
  @@map("form_submissions")
}

model FormSubmissionValue {
  id            String    @id @default(cuid())
  submission_id String
  field_id      String
  value_text    String?
  value_number  Float?
  value_date    DateTime?
  value_json    Json?
  value_file    String?

  submission FormSubmission @relation(fields: [submission_id], references: [id], onDelete: Cascade)
  field      FormField      @relation(fields: [field_id], references: [id])

  @@map("form_submission_values")
}

model FormSignature {
  id            String   @id @default(cuid())
  submission_id String
  signer_name   String
  signer_role   String?
  signer_doc    String?
  signature_url String
  signed_at     DateTime @default(now())

  submission FormSubmission @relation(fields: [submission_id], references: [id], onDelete: Cascade)

  @@map("form_signatures")
}

// ─── FORM BLUEPRINTS ──────────────────────────────────────

model FormBlueprint {
  id          String    @id @default(cuid())
  name        String
  description String?
  category    String
  is_global   Boolean   @default(false)
  org_id      String?
  fields      Json
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  organization Organization? @relation(fields: [org_id], references: [id])

  @@index([is_global])
  @@index([org_id])
  @@map("form_blueprints")
}

// ─── ECOSISTEMA KAIROS ────────────────────────────────────

model WebhookEndpoint {
  id          String   @id @default(cuid())
  org_id      String
  url         String
  secret      String
  event_types Json?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  org Organization @relation(fields: [org_id], references: [id])

  @@map("webhook_endpoints")
}

// ─── INVENTARIOS ADUANEROS ─────────────────────────────────

model InventarioSession {
  id                  String    @id @default(cuid())
  org_id              String
  tipo_formulario     String    @default("acta_inspeccion_previa")
  estado              String    @default("borrador")

  // Cabecera operacional
  agencia_aduanas     String?
  codigo_agencia      String?
  representante_legal String?
  mandato             String?
  deposito            String?
  direccion_deposito  String?
  documento_transporte String?
  manifiesto          String?
  fecha_manifiesto    DateTime?
  transportadora      String?
  consignatario       String?
  no_bultos           Int?
  peso                Float?
  precintos_retira    String?
  precintos_coloca    String?
  observaciones       String?   @db.Text

  // Firmas
  firmado_deposito_nombre String?
  firmado_agencia_nombre  String?
  firmado_deposito_url    String?
  firmado_agencia_url     String?
  firmado_deposito_at     DateTime?
  firmado_agencia_at      DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  org    Organization     @relation(fields: [org_id], references: [id])
  items  InventarioItem[]
  fotos  InventarioFoto[]

  @@index([org_id, estado])
  @@index([org_id, created_at(sort: Desc)])
  @@map("inventario_sessions")
}

model InventarioItem {
  id              String  @id @default(cuid())
  session_id      String
  numero          Int
  parte_no        String?
  pais            String?
  descripcion     String? @db.Text
  marca           String?
  modelo          String?
  serial          String?
  cantidad        Int?
  extraido_por_ia Boolean @default(false)
  tipo_novedad    String?

  session    InventarioSession     @relation(fields: [session_id], references: [id], onDelete: Cascade)
  accesorios InventarioAccesorio[]
  fotos      InventarioFoto[]

  @@index([session_id])
  @@map("inventario_items")
}

model InventarioAccesorio {
  id          String  @id @default(cuid())
  item_id     String
  parte_no    String?
  pais        String?
  descripcion String?
  marca       String?
  modelo      String?

  item InventarioItem @relation(fields: [item_id], references: [id], onDelete: Cascade)

  @@index([item_id])
  @@map("inventario_accesorios")
}

model InventarioFoto {
  id         String   @id @default(cuid())
  session_id String
  item_id    String?
  tipo       String
  url        String
  created_at DateTime @default(now())

  session InventarioSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  item    InventarioItem?   @relation(fields: [item_id], references: [id], onDelete: SetNull)

  @@index([session_id, tipo])
  @@map("inventario_fotos")
}

// ─── LISTAS MAESTRAS ─────────────────────────────────────

model MasterPosition {
  id         String    @id @default(cuid())
  org_id     String?           // null = global (seed de Kairos)
  name       String
  active     Boolean   @default(true)
  created_at DateTime  @default(now())

  org   Organization? @relation(fields: [org_id], references: [id], onDelete: Cascade)
  users User[]        @relation("UserPosition")

  @@unique([org_id, name])
  @@index([org_id, active])
  @@map("master_positions")
}

model MasterRole {
  id         String    @id @default(cuid())
  org_id     String?           // null = global (seed de Kairos)
  name       String
  active     Boolean   @default(true)
  created_at DateTime  @default(now())

  org Organization? @relation(fields: [org_id], references: [id], onDelete: Cascade)

  @@unique([org_id, name])
  @@index([org_id, active])
  @@map("master_roles")
}

model MasterListSuggestion {
  id           String           @id @default(cuid())
  org_id       String
  suggested_by String
  entity_type  MasterEntityType
  value        String
  status       SuggestionStatus @default(PENDING)
  reviewed_by  String?
  reviewed_at  DateTime?
  created_at   DateTime         @default(now())

  org       Organization @relation(fields: [org_id], references: [id])
  suggester User         @relation("SuggestedByUser", fields: [suggested_by], references: [id])
  reviewer  User?        @relation("ReviewedByUser", fields: [reviewed_by], references: [id])

  @@index([org_id, status])
  @@index([suggested_by])
  @@map("master_list_suggestions")
}

// ─── PLAN Y CONFIGURACIÓN DE ORG ──────────────────────────

model OrgConfig {
  id                        String    @id @default(cuid())
  org_id                    String    @unique
  plan                      PlanTier  @default(STARTER)
  max_users                 Int       @default(10)
  max_sites                 Int       @default(2)
  display_name              String
  logo_url                  String?
  primary_color             String?
  updated_at                DateTime  @updatedAt
  updated_by_super_admin_id String?

  org                    Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  updated_by_super_admin User?        @relation("SuperAdminOrgConfigUpdates", fields: [updated_by_super_admin_id], references: [id], onDelete: SetNull)

  @@map("org_configs")
}

// ─── MAGIC LINK ───────────────────────────────────────────

model MagicLinkToken {
  id                     String           @id @default(cuid())
  token                  String           @unique @default(cuid())
  user_id                String
  purpose                MagicLinkPurpose
  expires_at             DateTime
  used_at                DateTime?
  created_by_super_admin Boolean          @default(false)
  created_at             DateTime         @default(now())

  user User @relation("UserMagicLinks", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([user_id])
  @@map("magic_link_tokens")
}

// ─── FIRMA ELECTRÓNICA ────────────────────────────────────

model ExternalSigner {
  id                    String   @id @default(cuid())
  org_id                String
  work_location_id      String
  name                  String
  identification_number String
  phone                 String
  photo_id_key          String?
  selfie_key            String?
  is_registered         Boolean  @default(false)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  org               Organization     @relation(fields: [org_id], references: [id])
  work_location     WorkLocation     @relation(fields: [work_location_id], references: [id])
  signature_tokens  SignatureToken[]
  signature_records SignatureRecord[] @relation("ExternalSignerRecords")

  @@unique([work_location_id, identification_number])
  @@index([org_id, work_location_id])
  @@map("external_signers")
}

model SignatureToken {
  id                 String              @id @default(cuid())
  token              String              @unique @default(cuid())
  submission_id      String
  external_signer_id String
  link_status        SignatureLinkStatus @default(SENT)
  expires_at         DateTime
  viewed_at          DateTime?
  used_at            DateTime?
  created_at         DateTime            @default(now())

  submission       FormSubmission  @relation(fields: [submission_id], references: [id], onDelete: Cascade)
  external_signer  ExternalSigner  @relation(fields: [external_signer_id], references: [id], onDelete: Cascade)
  signature_record SignatureRecord? @relation("TokenSignatureRecord")

  @@index([submission_id])
  @@index([token])
  @@map("signature_tokens")
}

model SignatureRecord {
  id                  String     @id @default(cuid())
  submission_id       String
  signer_type         SignerType
  internal_user_id    String?
  external_signer_id  String?
  signature_token_id  String?    @unique
  ip_address          String?
  user_agent          String?    @db.Text
  geo_location        Json?
  webauthn_session    Boolean    @default(false)
  reading_log         Json
  min_reading_seconds Int        @default(30)
  stroke_image_base64 String     @db.Text
  stroke_vectors      Json
  document_hash       String
  hash_version        Int        @default(1)
  signed_at           DateTime   @default(now())

  submission      FormSubmission  @relation(fields: [submission_id], references: [id], onDelete: Restrict)
  internal_user   User?           @relation("InternalSignerRecords", fields: [internal_user_id], references: [id], onDelete: SetNull)
  external_signer ExternalSigner? @relation("ExternalSignerRecords", fields: [external_signer_id], references: [id], onDelete: SetNull)
  signature_token SignatureToken? @relation("TokenSignatureRecord", fields: [signature_token_id], references: [id], onDelete: SetNull)

  @@unique([submission_id, internal_user_id])
  @@index([submission_id])
  @@index([internal_user_id])
  @@index([external_signer_id])
  @@map("signature_records")
}

model SignatureConfig {
  id                     String        @id @default(cuid())
  template_id            String        @unique
  signature_mode         SignatureMode @default(FLEXIBLE)
  min_reading_seconds    Int           @default(30)
  requires_internal_sign Boolean       @default(true)
  created_at             DateTime      @default(now())
  updated_at             DateTime      @updatedAt

  template FormTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@map("signature_configs")
}

// ─── NOTIFICACIONES ───────────────────────────────────────

model Notification {
  id                  String           @id @default(cuid())
  user_id             String
  type                NotificationType
  title               String
  body                String           @db.Text
  read                Boolean          @default(false)
  read_at             DateTime?
  deep_link           String?
  created_at          DateTime         @default(now())
  created_by_admin_id String?

  user             User  @relation("UserNotifications", fields: [user_id], references: [id], onDelete: Cascade)
  created_by_admin User? @relation("AdminCreatedNotifications", fields: [created_by_admin_id], references: [id], onDelete: SetNull)

  @@index([user_id, read, created_at(sort: Desc)])
  @@index([created_by_admin_id])
  @@map("notifications")
}

// ─── ENUMS ────────────────────────────────────────────────

enum OAuthProvider {
  GOOGLE
  MICROSOFT
}

enum MasterEntityType {
  POSITION
  ROLE
  DEPARTMENT
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PlanTier {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum MagicLinkPurpose {
  FIRST_ACCESS_ADMIN
  ADMIN_INVITE
}

enum SignerType {
  INTERNAL
  EXTERNAL
}

enum SignatureLinkStatus {
  SENT
  VIEWED
  SIGNED
}

enum SignatureMode {
  STRICT
  FLEXIBLE
}

enum NotificationType {
  FORM_SUBMITTED
  FORM_APPROVED
  FORM_REJECTED
  FORM_PENDING_SIGNATURE
  MAGIC_LINK_SENT
  SYSTEM_ALERT
  CUSTOM_ADMIN
}

enum FormTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum FieldType {
  TEXT
  NUMBER
  DATE
  DATETIME
  SELECT
  MULTISELECT
  BOOLEAN
  SIGNATURE
  PHOTO
  GEOLOCATION
  FILE
}

enum Frequency {
  INHERIT
  NONE
  DAILY
  WEEKLY
  MONTHLY
  PER_EVENT
  ONCE
}

enum NotificationTrigger {
  ON_SUBMIT
  ON_APPROVE
  ON_REJECT
  SCHEDULED
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  PENDING_SIGNATURES
  APPROVED
  REJECTED
}
